# ──────────────────────────────────────────────────────
# MallSenseAI Configuration
# Copy to mallsenseai.env and edit before first install
# ──────────────────────────────────────────────────────

# ── Network ──
HOST_PORT=80                        # External access port (nginx)

# ── Application ──
APP_ENV=production                  # development | production
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR

# ── Database ──
POSTGRES_USER=mallsenseai
POSTGRES_PASSWORD=                  # Auto-generated on install if empty
POSTGRES_DB=mallsenseai

# ── Security ──
SECRET_KEY=                         # Auto-generated on install if empty
ACCESS_TOKEN_EXPIRE_MINUTES=480     # JWT token lifetime (8 hours)

# ── Detection ──
ALARM_INTERVAL_MINUTES=5            # Camera inspection interval
ALARM_DETECTION_MODE=max            # max | sum | yolo_only | image_only
ALARM_THRESHOLD=3000
ALARM_DIFF_THRESHOLD=18

# ── Paths (usually don't need to change) ──
DATA_DIR=/var/lib/mallsenseai       # Persistent data root
