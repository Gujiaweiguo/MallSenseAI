# MallSenseAI platform environment
APP_ENV=development
DEBUG=true
DATABASE_URL=sqlite:///./data/mallsenseai_dev.db
# Production example:
# DATABASE_URL=postgresql+psycopg2://mallsenseai:change-me@localhost:5432/mallsenseai
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ALARM_THRESHOLD=3000
ALARM_INTERVAL_MINUTES=1
ALARM_STATIC_WAIT_MINUTES=1
ALARM_DIFF_THRESHOLD=18
ALARM_ENABLE_YOLO_DETECTION=true
ALARM_ENABLE_IMAGE_COMPARISON=true
ALARM_DETECTION_MODE=max
